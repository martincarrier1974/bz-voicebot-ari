# ----- Tenant runtime -----
# Option recommandée en multi-client: un process Node par client.
# Définis le slug du client pour dériver automatiquement:
# runtime/tenants/<slug>/voicebot-config.json
RUNTIME_TENANT=bz-telecom

# Garde ARI_APP unique par process/client.
ARI_APP=voicebot-bz-telecom

# Option avancée: si tu veux forcer un chemin exact, décommente ceci.
# Prioritaire sur RUNTIME_TENANT.
# RUNTIME_CONFIG_PATH=runtime/tenants/bz-telecom/voicebot-config.json

# ----- ARI (Asterisk) -----
ARI_URL=http://127.0.0.1:8088
ARI_USER=voicebot
ARI_PASS=CHANGE_ME
# Tone à la prise d'appel (laisser vide ou commenté = pas de tone). Ex: sound:beep, tone:ring;tonezone=fr
# WELCOME_TONE=

# ----- Media / RTP -----
RTP_LISTEN_IP=0.0.0.0
RTP_LISTEN_PORT=40000
ASTERISK_PUBLIC_IP=127.0.0.1
# MEDIA_SERVER_IP=192.168.1.10
RTP_FORMAT=ulaw
SAMPLE_RATE=8000
TIMEZONE=America/Montreal

# ----- Microsoft 365 / Graph -----
M365_TENANT_ID=YOUR_TENANT_ID
M365_CLIENT_ID=YOUR_CLIENT_ID
M365_CLIENT_SECRET=YOUR_CLIENT_SECRET
CAL_SUPPORT=support@yourdomain.com
CAL_SALES=ventes@yourdomain.com
CAL_CABLING=cablage@yourdomain.com

# Business rules
APPT_DURATION_MIN=30
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=17:00
APPT_BUFFER_MIN=15

# ----- Deepgram (STT) + options TTS -----
DEEPGRAM_API_KEY=
DG_STT_MODEL=nova-3
DG_TTS_MODEL=aura-2-agathe-fr

# Recommandé pour une voix plus naturelle / québécoise : ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=
ELEVENLABS_LANGUAGE=multi

# ----- Agent conversationnel Deepgram (STT + LLM + TTS) -----
USE_DEEPGRAM_AGENT=false
DG_AGENT_LLM_MODEL=gpt-4o-mini
DG_AGENT_GREETING=Bienvenue chez BZ Telecom, comment pouvons-nous vous aider aujourd'hui ?
# DG_AGENT_PROMPT=

# Destinations ARI pour transfert (optionnel; défaut Local/101@from-internal)
# TRANSFER_POSTE_101=Local/101@from-internal
# TRANSFER_POSTE_102=Local/102@from-internal
# TRANSFER_POSTE_105=Local/105@from-internal

# ----- Voice AI (legacy / optional) -----
VOICE_AI_API_KEY=
