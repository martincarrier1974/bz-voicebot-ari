# ----- ARI (Asterisk) -----
ARI_URL=http://127.0.0.1:8088
ARI_USER=voicebot
ARI_PASS=CHANGE_ME
ARI_APP=voicebot
# Tone joué à la prise d'appel (sound:beep, tone:ring;tonezone=fr, etc.)
# WELCOME_TONE=sound:beep

# ----- Media / RTP -----
# Local UDP port where YOUR media server listens for RTP from Asterisk ExternalMedia
RTP_LISTEN_IP=0.0.0.0
RTP_LISTEN_PORT=40000

# If your Asterisk is behind NAT / different interface, note it here
ASTERISK_PUBLIC_IP=127.0.0.1
# IP utilisée pour external_host (si vide, utilise ASTERISK_PUBLIC_IP)
# MEDIA_SERVER_IP=192.168.1.10

# Audio format used with ExternalMedia (ulaw typical for telephony, or slin16)
RTP_FORMAT=ulaw
SAMPLE_RATE=8000
TIMEZONE=America/Montreal

# ----- Microsoft 365 / Graph -----
M365_TENANT_ID=YOUR_TENANT_ID
M365_CLIENT_ID=YOUR_CLIENT_ID
M365_CLIENT_SECRET=YOUR_CLIENT_SECRET

# Multi-calendar routing (service -> mailbox)
CAL_SUPPORT=support@yourdomain.com
CAL_SALES=ventes@yourdomain.com
CAL_CABLING=cablage@yourdomain.com

# Business rules
APPT_DURATION_MIN=30
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=17:00
APPT_BUFFER_MIN=15

# ----- Deepgram (STT + TTS) -----
DEEPGRAM_API_KEY=
DG_STT_MODEL=nova-2
DG_TTS_MODEL=aura-asteria-en

# ----- Voice AI (legacy / optional) -----
VOICE_AI_API_KEY=
