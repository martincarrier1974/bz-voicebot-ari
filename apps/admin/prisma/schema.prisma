generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                String               @id @default(cuid())
  name              String
  slug              String               @unique
  runtimeConfigPath String?
  notes             String?
  isActive          Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  prompts             Prompt[]
  contexts            Context[]
  routeRules          RouteRule[]
  flows               Flow[]
  directoryContacts   DirectoryContact[]
  settings            Setting[]
  bookingServices     BookingService[]
  calendarConnections CalendarConnection[]
  calendarResources   CalendarResource[]

  @@index([isActive, name])
}

model Prompt {
  id          String          @id @default(cuid())
  tenantId    String?
  key         String
  name        String
  scenario    String
  description String?
  content     String
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tenant      Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions    PromptVersion[]

  @@unique([tenantId, key])
  @@index([tenantId, scenario])
}

model PromptVersion {
  id         String   @id @default(cuid())
  promptId   String
  content    String
  note       String?
  createdAt  DateTime @default(now())
  prompt     Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
}

model Context {
  id               String   @id @default(cuid())
  tenantId         String?
  name             String
  description      String
  instructions     String
  voiceTone        String
  rules            String
  limits           String
  responseExamples String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flows            Flow[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

model RouteRule {
  id          String       @id @default(cuid())
  tenantId    String?
  serviceName String
  extension   String
  keywords    String
  priority    Int          @default(100)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tenant      Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  intents     FlowIntent[]

  @@unique([tenantId, serviceName])
  @@index([tenantId, extension])
  @@index([tenantId, isActive, priority])
}

model Flow {
  id                String       @id @default(cuid())
  tenantId          String?
  name              String
  welcomeMessage    String
  silencePrompt     String
  ambiguousPrompt   String
  fallbackPrompt    String
  finalAction       String
  destinationLabel  String
  destinationPost   String
  maxFailedAttempts Int          @default(2)
  isActive          Boolean      @default(true)
  contextId         String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  tenant            Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  context           Context?     @relation(fields: [contextId], references: [id], onDelete: SetNull)
  intents           FlowIntent[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive, updatedAt])
}

model FlowIntent {
  id              String     @id @default(cuid())
  flowId          String
  routeRuleId     String?
  label           String
  keywords        String
  response        String
  finalAction     String
  destinationPost String
  priority        Int        @default(100)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  flow            Flow       @relation(fields: [flowId], references: [id], onDelete: Cascade)
  routeRule       RouteRule? @relation(fields: [routeRuleId], references: [id], onDelete: SetNull)
}

model DirectoryContact {
  id           String   @id @default(cuid())
  tenantId     String?
  extension    String
  name         String
  aliases      String   @default("")
  voicemail    String?
  tech         String?
  source       String
  isActive     Boolean  @default(true)
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, extension])
  @@index([tenantId, isActive, name])
}

model Setting {
  id        String   @id @default(cuid())
  tenantId  String?
  key       String
  label     String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId, label])
}

model BookingService {
  id              String                   @id @default(cuid())
  tenantId        String?
  name            String
  slug            String
  description     String?
  durationMin     Int
  bufferBeforeMin Int                      @default(0)
  bufferAfterMin  Int                      @default(0)
  isActive        Boolean                  @default(true)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  tenant          Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  resources       BookingServiceResource[]

  @@unique([tenantId, name])
  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
}

model CalendarConnection {
  id                String             @id @default(cuid())
  tenantId          String?
  name              String
  provider          String
  tenantExternalId  String?
  clientId          String?
  clientSecret      String?
  refreshToken      String?
  accountEmail      String?
  defaultCalendarId String?
  timezone          String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenant            Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  resources         CalendarResource[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

model CalendarResource {
  id               String                   @id @default(cuid())
  tenantId         String?
  name             String
  employeeName     String?
  calendarId       String
  calendarAddress  String?
  timezone         String?
  bookingNotes     String?
  connectionId     String
  isActive         Boolean                  @default(true)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  tenant           Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection       CalendarConnection       @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  services         BookingServiceResource[]

  @@unique([connectionId, calendarId])
  @@index([tenantId, isActive, name])
}

model BookingServiceResource {
  id                 String           @id @default(cuid())
  bookingServiceId   String
  calendarResourceId String
  priority           Int              @default(100)
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  bookingService     BookingService   @relation(fields: [bookingServiceId], references: [id], onDelete: Cascade)
  calendarResource   CalendarResource @relation(fields: [calendarResourceId], references: [id], onDelete: Cascade)

  @@unique([bookingServiceId, calendarResourceId])
}
